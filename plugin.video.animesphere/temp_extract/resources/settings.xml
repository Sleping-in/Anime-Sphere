        <category label="32000" help="API Settings">
            <setting id="mal_client_id" type="string" label="32001" default="">
                <level>0</level>
                <constraints>
                    <allowempty>false</allowempty>
                </constraints>
                <help>MyAnimeList API client ID</help>
            </setting>
            <setting id="mal_access_token" type="string" label="32002" default="">
                <level>0</level>
                <constraints>
                    <allowempty>false</allowempty>
                </constraints>
                <help>MyAnimeList API access token</help>
            </setting>
            <setting id="api_debug" type="bool" label="32003" default="false">
                <help>Enable API debug logging</help>
            </setting>
            <setting id="api_timeout" type="number" label="32004" default="30" min="5" max="120">
                <help>API request timeout in seconds</help>
            </setting>
            <setting id="api_retries" type="number" label="32005" default="3" min="1" max="5">
                <help>Number of retries for failed API requests</help>
            </setting>
        </category>
        <category label="32010" help="Watchlist Settings">
            <setting id="watchlist_sort" type="enum" label="32011" default="0">
                <help>Sort order for watchlist items</help>
                <constraints>
                    <options>
                        <option label="Title">0</option>
                        <option label="Score">1</option>
                        <option label="Progress">2</option>
                        <option label="Date Added">3</option>
                        <option label="Date Updated">4</option>
                        <option label="Episode Count">5</option>
                    </options>
                </constraints>
            </setting>
            <setting id="watchlist_order" type="enum" label="32012" default="0">
                <help>Sort direction for watchlist items</help>
                <constraints>
                    <options>
                        <option label="Ascending">0</option>
                        <option label="Descending">1</option>
                    </options>
                </constraints>
            </setting>
            <setting id="show_progress" type="bool" label="32013" default="true">
                <help>Show progress bars in watchlist</help>
            </setting>
            <setting id="reminder_enabled" type="bool" label="32014" default="true">
                <help>Enable episode reminder notifications</help>
            </setting>
            <setting id="watchlist_limit" type="number" label="32015" default="100" min="10" max="1000">
                <help>Maximum number of items to show in watchlist</help>
            </setting>
            <setting id="watchlist_refresh" type="enum" label="32016" default="60">
                <help>Watchlist refresh interval in minutes</help>
                <constraints>
                    <options>
                        <option label="Never">0</option>
                        <option label="15 minutes">15</option>
                        <option label="30 minutes">30</option>
                        <option label="1 hour">60</option>
                        <option label="2 hours">120</option>
                    </options>
                </constraints>
            </setting>
            <setting id="watchlist_group_by" type="enum" label="32017" default="0">
                <help>Group watchlist items by category</help>
                <constraints>
                    <options>
                        <option label="None">0</option>
                        <option label="Status">1</option>
                        <option label="Genre">2</option>
                        <option label="Year">3</option>
                        <option label="Season">4</option>
                    </options>
                </constraints>
            </setting>
        </category>
        <category label="32020" help="Sync Settings">
            <setting id="sync_trakt" type="bool" label="32021" default="false">
                <help>Enable Trakt.tv synchronization</help>
            </setting>
            <setting id="sync_anilist" type="bool" label="32022" default="false">
                <help>Enable AniList synchronization</help>
            </setting>
            <setting id="sync_kitsu" type="bool" label="32023" default="false">
                <help>Enable Kitsu synchronization</help>
            </setting>
            <setting id="sync_shikimori" type="bool" label="32024" default="false">
                <help>Enable Shikimori synchronization</help>
            </setting>
            <setting id="sync_anidb" type="bool" label="32025" default="false">
                <help>Enable AniDB synchronization</help>
            </setting>
            <setting id="sync_interval" type="enum" label="32026" default="60">
                <help>Sync interval in minutes</help>
                <constraints>
                    <options>
                        <option label="Never">0</option>
                        <option label="15 minutes">15</option>
                        <option label="30 minutes">30</option>
                        <option label="1 hour">60</option>
                        <option label="2 hours">120</option>
                    </options>
                </constraints>
            </setting>
            <setting id="sync_priority" type="enum" label="32027" default="0">
                <help>Sync priority order</help>
                <constraints>
                    <options>
                        <option label="MAL First">0</option>
                        <option label="Trakt First">1</option>
                        <option label="AniList First">2</option>
                        <option label="Kitsu First">3</option>
                        <option label="Shikimori First">4</option>
                        <option label="AniDB First">5</option>
                    </options>
                </constraints>
            </setting>
            <setting id="sync_conflict" type="enum" label="32028" default="0">
                <help>Conflict resolution strategy</help>
                <constraints>
                    <options>
                        <option label="Keep MAL">0</option>
                        <option label="Update MAL">1</option>
                        <option label="Ask Each Time">2</option>
                    </options>
                </constraints>
            </setting>
        </category>
        <category label="32030" help="Recommendation Settings">
            <setting id="recommendation_type" type="enum" label="32031" default="0">
                <help>Type of recommendations to show</help>
                <constraints>
                    <options>
                        <option label="Personalized">0</option>
                        <option label="Trending">1</option>
                        <option label="Seasonal">2</option>
                        <option label="Random">3</option>
                        <option label="Popular">4</option>
                        <option label="Upcoming">5</option>
                    </options>
                </constraints>
            </setting>
            <setting id="max_recommendations" type="number" label="32032" default="10" min="1" max="50">
                <help>Maximum number of recommendations to show</help>
            </setting>
            <setting id="include_genres" type="text" label="32033" default="">
                <help>Comma-separated list of genres to include</help>
            </setting>
            <setting id="exclude_genres" type="text" label="32034" default="">
                <help>Comma-separated list of genres to exclude</help>
            </setting>
            <setting id="min_score" type="number" label="32035" default="7.5" min="0" max="10" step="0.1">
                <help>Minimum score for recommendations</help>
            </setting>
            <setting id="max_age" type="number" label="32036" default="5" min="0" max="100">
                <help>Maximum age of recommendations in years</help>
            </setting>
            <setting id="recommendation_refresh" type="enum" label="32037" default="24">
                <help>Recommendation refresh interval in hours</help>
                <constraints>
                    <options>
                        <option label="Never">0</option>
                        <option label="1 hour">1</option>
                        <option label="6 hours">6</option>
                        <option label="12 hours">12</option>
                        <option label="24 hours">24</option>
                    </options>
                </constraints>
            </setting>
        </category>
        <category label="32040" help="Notification Settings">
            <setting id="notify_new_episodes" type="bool" label="32041" default="true">
                <help>Notify about new episodes</help>
            </setting>
            <setting id="notify_watchlist_updates" type="bool" label="32042" default="true">
                <help>Notify about watchlist updates</help>
            </setting>
            <setting id="notify_recommendations" type="bool" label="32043" default="true">
                <help>Notify about new recommendations</help>
            </setting>
            <setting id="notify_reminders" type="bool" label="32044" default="true">
                <help>Notify about episode reminders</help>
            </setting>
            <setting id="notification_duration" type="number" label="32045" default="5" min="1" max="30">
                <help>Notification display duration in seconds</help>
            </setting>
            <setting id="notification_sound" type="bool" label="32046" default="true">
                <help>Play sound with notifications</help>
            </setting>
            <setting id="notification_sound_path" type="file" label="32047" default="">
                <help>Path to custom notification sound</help>
            </setting>
            <setting id="notification_position" type="enum" label="32048" default="0">
                <help>Notification position on screen</help>
                <constraints>
                    <options>
                        <option label="Top">0</option>
                        <option label="Bottom">1</option>
                        <option label="Center">2</option>
                    </options>
                </constraints>
            </setting>
            <setting id="notification_style" type="enum" label="32049" default="0">
                <help>Notification style</help>
                <constraints>
                    <options>
                        <option label="Standard">0</option>
                        <option label="Minimal">1</option>
                        <option label="Detailed">2</option>
                    </options>
                </constraints>
            </setting>
        </category>
        <category label="32050" help="Player Settings">
            <setting id="player_type" type="enum" label="32051" default="0">
                <help>Default player type</help>
                <constraints>
                    <options>
                        <option label="Default">0</option>
                        <option label="External">1</option>
                        <option label="Stream">2</option>
                        <option label="Custom">3</option>
                    </options>
                </constraints>
            </setting>
            <setting id="external_player_path" type="file" label="32052" default="" visible="eq(-1,1)">
                <help>Path to external player executable</help>
            </setting>
            <setting id="external_player_args" type="text" label="32053" default="" visible="eq(-1,1)">
                <help>Arguments for external player</help>
            </setting>
            <setting id="stream_quality" type="enum" label="32054" default="0">
                <help>Default stream quality</help>
                <constraints>
                    <options>
                        <option label="Auto">0</option>
                        <option label="1080p">1</option>
                        <option label="720p">2</option>
                        <option label="480p">3</option>
                        <option label="360p">4</option>
                    </options>
                </constraints>
            </setting>
            <setting id="stream_protocol" type="enum" label="32055" default="0">
