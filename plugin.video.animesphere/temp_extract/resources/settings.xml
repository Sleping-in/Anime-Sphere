            <setting id="analytics_anonymize" type="bool" label="32094" default="true">
                <help>Anonymize analytics data</help>
            </setting>
        </category>
        <category label="32100" help="Accessibility Settings">
            <setting id="screen_reader" type="bool" label="32101" default="true">
