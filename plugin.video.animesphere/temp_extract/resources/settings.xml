                <constraints>
                    <options>
                        <option label="HLS">0</option>
                        <option label="DASH">1</option>
                        <option label="RTMP">2</option>
                        <option label="HTTP">3</option>
                    </options>
                </constraints>
            </setting>
            <setting id="buffer_size" type="number" label="32056" default="5" min="1" max="30">
